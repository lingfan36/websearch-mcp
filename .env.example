# ===========================================
# WebSearch MCP Server Configuration
# ===========================================

# Ollama LLM Configuration
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=120

# Typesense Configuration (optional, for indexed search)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_KEY=

# Crawler Configuration
CRAWL_DELAY=1.0
CRAWL_CONCURRENCY=3
CRAWL_MAX_PAGES=100

# Server Configuration
SERVER_NAME=websearch-mcp
LOG_LEVEL=INFO

# Optional: External APIs (not implemented yet)
# SERPER_API_KEY=your_key
# BING_API_KEY=your_key